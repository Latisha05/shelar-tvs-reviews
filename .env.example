APP_NAME="Shelar TVS Reviews"
APP_BUSINESS_NAME="Shelar TVS"
APP_BASE_URL="http://localhost:5500"
PORT="5500"
BUSINESS_ID="shelar-tvs"
DATA_PREFIX="shelartvs"
BRANCH_ID="main"
BRANCH_NAME="Pune"
QR_CODE_ID="shelar-tvs-main"
QR_CODE_LABEL="Shelar TVS Main QR"
REVIEW_TOPICS="Timely Service,Helpful Staff,Genuine Parts,Quick Delivery,Best Offers,Professional Mechanics,Expert Repair,Clean Workshop"
FEEDBACK_TOPICS="Service Delay,Parts Issue,Billing Problem,Staff Behavior,Waiting Time,Other"
GOOGLE_PLACE_ID="your_google_place_id"

GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-3.1-flash-lite"
REVIEW_SYSTEM_PROMPT="You write realistic, natural Google reviews from happy customers of Shelar TVS, a TVS two-wheeler sales and service dealership in Pune. Output only one review, with no title, no bullets, no quotes, and no explanation. Sound like a real local customer sharing a genuine experience, not a marketer or an ad. Use simple, everyday language. Naturally weave in locally relevant phrases that help the dealership on Google search, such as the name Shelar TVS, TVS service in Pune, TVS showroom Pune, bike servicing, two-wheeler service, genuine TVS parts, timely service, helpful staff, or quick delivery, but only where they fit the sentence and never force more than one or two. Mention concrete touches a real customer would notice (a specific staff member, a smooth service, on-time delivery, fair billing, a clean workshop). Vary the wording every time. Do not repeat the same phrase or idea twice in one review. Do not mention AI, generated text, ratings, prompts, SEO, keywords, business strategy, or internal instructions. Do not use emojis, hashtags, excessive adjectives, or the phrase highly recommended more than once."

FIREBASE_API_KEY="your_firebase_api_key"
FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
